<Window
    x:Class="Velo.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Velo.App"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:p="using:Microsoft.UI.Xaml.Controls.Primitives">

    <!-- Frameless. Three real columns — details | terminal | tabs — so the panels
         genuinely PUSH the terminal (no overlay/slide desync): toggling a panel
         animates its column width, the `*` terminal column reflows in lockstep. The
         toggles sit in the terminal column anchored to its edges, so they track the
         panel boundary automatically; their inner bar animates wide<->narrow. -->
    <Grid x:Name="RootGrid" KeyboardAcceleratorPlacementMode="Hidden">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="B" Invoked="PaneToggleAccel_Invoked" />
            <KeyboardAccelerator Modifiers="Control,Shift" Key="B" Invoked="DetailsToggleAccel_Invoked" />
            <KeyboardAccelerator Modifiers="Control,Shift" Key="P" Invoked="PaletteAccel_Invoked" />
            <KeyboardAccelerator Modifiers="Control" Key="P" Invoked="PaletteAccel_Invoked" />
        </Grid.KeyboardAccelerators>

        <Grid.Resources>
            <!-- Tab list rows: a tab row, or a group-header row. Selected by TabRowSelector. -->
            <!-- Classic Binding (no x:Bind/x:DataType): the TabVM<->TabGroup
                 reference cycle makes the WinUI 1.6 x:Bind validation-context
                 generator recurse forever -> silent XamlCompiler StackOverflow. -->
            <DataTemplate x:Key="TabRowTemplate">
                <Grid ColumnSpacing="8"
                      Margin="{Binding RowIndent, Mode=OneWay}"
                      Background="Transparent"
                      PointerPressed="TabRow_PointerPressed"
                      PointerEntered="TabRow_PointerEntered"
                      PointerExited="TabRow_PointerExited"
                      DoubleTapped="TabRow_DoubleTapped"
                      ContextRequested="TabRow_ContextRequested">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- The ONLY row fill: active, hover, and ctrl-select all share
                         this one Border (presenter draws no background), so every
                         state is identical brush + geometry and can never stack. -->
                    <Border Grid.ColumnSpan="4"
                            Margin="-10,0,-8,0"
                            CornerRadius="7"
                            Background="{ThemeResource ListViewItemBackgroundSelected}"
                            Opacity="{Binding FillOpacity, Mode=OneWay}"
                            IsHitTestVisible="False" />
                    <!-- Group colour accent bar. -->
                    <Border Grid.Column="0"
                            Width="3" Height="16"
                            CornerRadius="2"
                            VerticalAlignment="Center"
                            Background="{Binding AccentBrush, Mode=OneWay}"
                            Visibility="{Binding AccentVisibility, Mode=OneWay}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Title, Mode=OneWay}"
                               Visibility="{Binding TitleVisibility, Mode=OneWay}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="1"
                             Name="RenameBox"
                             Text="{Binding Title, Mode=OneWay}"
                             Visibility="{Binding EditVisibility, Mode=OneWay}"
                             VerticalAlignment="Center"
                             MinHeight="0" Height="26"
                             Padding="6,2"
                             KeyDown="RenameBox_KeyDown"
                             LostFocus="RenameBox_LostFocus" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding Badge, Mode=OneWay}"
                               VerticalAlignment="Center"
                               Opacity="0.7" />
                    <TextBlock Grid.Column="3"
                               Name="ShellKindText"
                               Text="{Binding ShellKind, Mode=OneWay}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               FontSize="11"
                               Opacity="0.5" />
                    <Button Grid.Column="3"
                            Opacity="0"
                            Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="11"
                            Width="24" Height="24"
                            Padding="0"
                            CornerRadius="6"
                            Background="Transparent"
                            BorderThickness="0"
                            Tag="{Binding Id}"
                            Click="TabClose_Click" />
                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="GroupHeaderTemplate">
                <Grid ColumnSpacing="6"
                      Padding="0,6"
                      Background="Transparent"
                      Tapped="GroupHeader_Tapped"
                      DoubleTapped="GroupHeader_DoubleTapped"
                      PointerEntered="GroupHeader_PointerEntered"
                      PointerExited="GroupHeader_PointerExited"
                      ContextRequested="GroupHeader_ContextRequested">
                    <!-- ColumnDefinitions MUST precede content children: a child
                         element before this property element made the WinUI 1.6
                         XamlCompiler pass1 parser recurse forever -> silent
                         XamlCompiler.exe exit-1 (StackOverflow, no error). -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- Hover fill (presenter hover is disabled for the whole list;
                         drawn here so the header still highlights on hover). Margin
                         cancels the presenter ContentMargin + this Grid's padding so
                         it fills the row like the old presenter fill did. -->
                    <Border x:Name="HoverFill"
                            Grid.ColumnSpan="4"
                            Margin="-10,-6,-8,-6"
                            CornerRadius="7"
                            Background="{ThemeResource ListViewItemBackgroundSelected}"
                            Opacity="0"
                            IsHitTestVisible="False" />
                    <!-- Separator hairline between consecutive groups (hidden on the
                         first group via SeparatorVisibility). Spans nearly the full
                         panel width to match the design. -->
                    <Border Grid.ColumnSpan="4"
                            Height="1"
                            VerticalAlignment="Top"
                            Margin="-14,-6,-12,0"
                            Visibility="{Binding SeparatorVisibility, Mode=OneWay}"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <FontIcon Grid.Column="0"
                              Width="22" Height="22"
                              FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              FontSize="11"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Glyph="{Binding ChevronGlyph, Mode=OneWay}" />
                    <Ellipse Grid.Column="1"
                             Width="9" Height="9"
                             VerticalAlignment="Center"
                             Fill="{Binding ColorBrush, Mode=OneWay}" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding Name, Mode=OneWay}"
                               Visibility="{Binding NameVisibility, Mode=OneWay}"
                               FontWeight="SemiBold"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                    <TextBox Grid.Column="2"
                             Name="RenameBox"
                             Text="{Binding Name, Mode=OneWay}"
                             Visibility="{Binding EditVisibility, Mode=OneWay}"
                             VerticalAlignment="Center"
                             MinHeight="0" Height="26"
                             Padding="6,2"
                             KeyDown="RenameBox_KeyDown"
                             LostFocus="RenameBox_LostFocus" />
                    <Button Grid.Column="3"
                            Style="{StaticResource IconButtonStyle}"
                            Content="&#xE712;"
                            FontSize="12"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Click="GroupMenu_Click" />
                </Grid>
            </DataTemplate>

        </Grid.Resources>

        <!-- Three real columns: details panel | terminal | tabs panel. Toggling a
             panel animates its column's WIDTH (Auto columns track the panel Border
             width), so the terminal genuinely reflows in lockstep — no overlay/slide
             desync. Side columns are 0-wide when their panel is closed. -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Center column: titlebar + terminal. Background stays TRANSPARENT so the
             terminal swapchain composites directly over the window backdrop (a single
             tint layer). If ContentRoot itself were tinted, the swapchain would stack
             a second layer over it → terminal darker than the panels + opacity barely
             responding. The thin title bar gets the surface tint on its own. -->
        <Grid x:Name="ContentRoot" Grid.Column="1" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Thin title bar: just tall enough for the toggle icons + small
                 padding. No title text (drag + double-click-maximize only). -->
            <Grid x:Name="TitleBar" Grid.Row="0" Background="Transparent"
                  SizeChanged="TitleBar_SizeChanged">
                <TextBlock x:Name="TitleBarTitle"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="12"
                           MaxWidth="420"
                           TextTrimming="CharacterEllipsis"
                           IsHitTestVisible="False"
                           Opacity="0.8" />
            </Grid>

            <!-- Pane host: a 2x2 grid holding up to 4 terminal panes.
                 ponytail: background is Transparent (shows ContentRoot's terminal-
                 matching bg) so that while the swapchain lags a per-frame column
                 resize, the exposed strip matches the terminal instead of flashing
                 a gray band. Trade-off: the 1px split separators are no longer
                 divider-colored (invisible in splits) — restore a divider brush here
                 if visible pane separators matter more than the resize seam. -->
            <!-- PaneHost is the keyboard target: SwapChainPanel can't take focus
                 (no Background / not hit-testable), but this transparent Grid can. -->
            <Grid x:Name="PaneHost"
                  Grid.Row="1"
                  Background="Transparent"
                  IsTabStop="True"
                  ColumnSpacing="1"
                  RowSpacing="1"
                  Loaded="PaneHost_Loaded"
                  PointerPressed="PaneHost_PointerPressed"
                  PointerMoved="PaneHost_PointerMoved"
                  PointerReleased="PaneHost_PointerReleased"
                  PointerWheelChanged="PaneHost_PointerWheelChanged">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <SwapChainPanel x:Name="TerminalPanel"
                                Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="2"
                                IsTabStop="True"
                                SizeChanged="Panel_SizeChanged"
                                Loaded="TerminalPanel_Loaded"
                                KeyDown="Panel_KeyDown"
                                CharacterReceived="Panel_CharacterReceived" />

                <SwapChainPanel x:Name="TerminalPanel1"
                                Visibility="Collapsed"
                                IsTabStop="True"
                                SizeChanged="Panel_SizeChanged"
                                KeyDown="Panel_KeyDown"
                                CharacterReceived="Panel_CharacterReceived" />
                <SwapChainPanel x:Name="TerminalPanel2"
                                Visibility="Collapsed"
                                IsTabStop="True"
                                SizeChanged="Panel_SizeChanged"
                                KeyDown="Panel_KeyDown"
                                CharacterReceived="Panel_CharacterReceived" />
                <SwapChainPanel x:Name="TerminalPanel3"
                                Visibility="Collapsed"
                                IsTabStop="True"
                                SizeChanged="Panel_SizeChanged"
                                KeyDown="Panel_KeyDown"
                                CharacterReceived="Panel_CharacterReceived" />

                <!-- Drop-zone overlay (a single highlight repositioned per edge). -->
                <Grid x:Name="SplitOverlay"
                      Grid.RowSpan="2" Grid.ColumnSpan="2"
                      Visibility="Collapsed"
                      IsHitTestVisible="False">
                    <Border x:Name="DropZone"
                            Opacity="0"
                            Background="#3340A0FF"
                            BorderBrush="#A040A0FF"
                            BorderThickness="2"
                            CornerRadius="4" />
                </Grid>

                <!-- Zoom-level toast: floats over the body, bottom-centered, fades
                     out shortly after each Ctrl++/Ctrl+- step. -->
                <Border x:Name="ZoomToast"
                        Grid.RowSpan="2" Grid.ColumnSpan="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,48"
                        Padding="16,9"
                        CornerRadius="8"
                        Background="#E6242424"
                        Opacity="0"
                        IsHitTestVisible="False">
                    <TextBlock x:Name="ZoomToastText"
                               Text="100%"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White" />
                </Border>
            </Grid>

            <!-- Editor mode host: file tab strip + editor swapchain. Shown in
                 place of PaneHost while editor mode is on; terminal panes stay
                 alive underneath (hidden, not destroyed). -->
            <Grid x:Name="EditorHost"
                  Grid.Row="1"
                  Visibility="Collapsed"
                  Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition Height="36" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ListView x:Name="EditorTabs"
                          Grid.Row="0"
                          ItemsSource="{x:Bind EditorFiles}"
                          SelectionMode="Single"
                          SelectionChanged="EditorTabs_SelectionChanged"
                          ScrollViewer.HorizontalScrollMode="Enabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Hidden">
                    <ListView.Resources>
                        <!-- Presenter backgrounds off entirely: it draws square
                             fills that ignore CornerRadius. The rounded pill is a
                             Border inside the item template instead. -->
                        <SolidColorBrush x:Key="ListViewItemBackground" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="Transparent" />
                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="Transparent" />
                    </ListView.Resources>
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="MinHeight" Value="30" />
                            <Setter Property="MinWidth" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="2,0" />
                            <Setter Property="CornerRadius" Value="6" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:EditorFileVM">
                            <Border CornerRadius="6"
                                    Padding="14,5,8,5"
                                    Background="{x:Bind SelectedBrush, Mode=OneWay}">
                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{x:Bind Name}"
                                           VerticalAlignment="Center"
                                           FontSize="12" />
                                <Ellipse Grid.Column="1"
                                         Width="7" Height="7"
                                         Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                         Visibility="{x:Bind DirtyVisibility, Mode=OneWay}"
                                         VerticalAlignment="Center" />
                                <Button Grid.Column="2"
                                        Content="&#xE711;"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="10"
                                        Width="22" Height="22"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Tag="{x:Bind Id}"
                                        Click="EditorTabClose_Click" />
                            </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <SwapChainPanel x:Name="EditorPanel"
                                Grid.Row="1"
                                IsTabStop="True"
                                SizeChanged="EditorPanel_SizeChanged"
                                KeyDown="EditorPanel_KeyDown"
                                CharacterReceived="EditorPanel_CharacterReceived"
                                PointerPressed="EditorPanel_PointerPressed"
                                PointerMoved="EditorPanel_PointerMoved"
                                PointerReleased="EditorPanel_PointerReleased"
                                PointerWheelChanged="EditorPanel_PointerWheelChanged" />

                <!-- Ctrl+J bottom terminal: shows the active tab's live session.
                     Transparent Grid takes keyboard focus (SwapChainPanel can't),
                     same pattern as PaneHost. -->
                <Grid x:Name="EditorTermHost"
                      Grid.Row="2"
                      Height="220"
                      Visibility="Collapsed"
                      Background="Transparent"
                      IsTabStop="True"
                      KeyDown="EditorTerm_KeyDown"
                      CharacterReceived="Panel_CharacterReceived"
                      PointerPressed="EditorTerm_PointerPressed"
                      PointerWheelChanged="EditorTerm_PointerWheelChanged">
                    <SwapChainPanel x:Name="EditorTermPanel"
                                    SizeChanged="EditorTerm_SizeChanged" />
                </Grid>
            </Grid>
        </Grid>

        <!-- Title-bar hover/drag strip: full-width, transparent, above the terminal
             but below the chrome buttons. Drives window drag (manual, so the whole
             strip is draggable) + double-click maximize, and reveals the toggles on
             hover anywhere along the bar. -->
        <Border x:Name="TitleBarHover"
                Grid.Column="1"
                VerticalAlignment="Top"
                Height="34"
                Background="Transparent"
                PointerEntered="Chrome_PointerEntered"
                PointerExited="Chrome_PointerExited"
                PointerPressed="TitleBarHover_PointerPressed"
                PointerMoved="TitleBarHover_PointerMoved"
                PointerReleased="TitleBarHover_PointerReleased"
                DoubleTapped="TitleBarHover_DoubleTapped" />

        <!-- Details panel: LEFT column. Holds Info/Outline/Git/Files, switched by
             the icon row. Closed = column width 0; opening animates Width to 280,
             genuinely pushing the terminal. Clipped so content never spills past its
             animating width. -->
        <Border x:Name="DetailsSurface"
                Grid.Column="0"
                Width="0"
                SizeChanged="Panel_ClipToBounds"
                BorderThickness="0,0,1,0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                Background="Transparent">
            <!-- Fixed-width content (stable, no reflow); the Border owns the column
                 width (set instantly on toggle) and clips the content to it. -->
            <Grid Width="280" HorizontalAlignment="Left">
                <Grid.RowDefinitions>
                    <RowDefinition Height="34" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Row 0: detail-section icon row (hover-only chrome). Each button
                     shows its icon always; the selected one also reveals its text
                     label. -->
                <StackPanel x:Name="DetailsIconRow"
                            Grid.Row="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="2"
                            PointerEntered="Chrome_PointerEntered"
                            PointerExited="Chrome_PointerExited"
                            SizeChanged="TitleBar_SizeChanged">
                    <Button x:Name="InfoTabButton" Style="{StaticResource SectionButtonStyle}"
                            Tag="Info" Click="DetailsTab_Click" ToolTipService.ToolTip="Info">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE946;" FontSize="14" FontFamily="Segoe MDL2 Assets" />
                            <TextBlock x:Name="InfoLabel" Text="Info" Visibility="Collapsed" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="OutlineTabButton" Style="{StaticResource SectionButtonStyle}"
                            Tag="Outline" Click="DetailsTab_Click" ToolTipService.ToolTip="Outline">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8FD;" FontSize="14" FontFamily="Segoe MDL2 Assets" />
                            <TextBlock x:Name="OutlineLabel" Text="Outline" Visibility="Collapsed" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="GitTabButton" Style="{StaticResource SectionButtonStyle}"
                            Tag="Git" Click="DetailsTab_Click" ToolTipService.ToolTip="Git">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <!-- Lucide git-compare-arrows (stroke). -->
                            <Viewbox Width="15" Height="15">
                                <Canvas Width="24" Height="24">
                                    <Canvas.Resources>
                                        <Style TargetType="Path">
                                            <Setter Property="Stroke" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <Setter Property="StrokeThickness" Value="2" />
                                            <Setter Property="StrokeLineJoin" Value="Round" />
                                            <Setter Property="StrokeStartLineCap" Value="Round" />
                                            <Setter Property="StrokeEndLineCap" Value="Round" />
                                        </Style>
                                    </Canvas.Resources>
                                    <Ellipse Canvas.Left="2" Canvas.Top="3" Width="6" Height="6"
                                             Stroke="{ThemeResource TextFillColorSecondaryBrush}" StrokeThickness="2" />
                                    <Ellipse Canvas.Left="16" Canvas.Top="15" Width="6" Height="6"
                                             Stroke="{ThemeResource TextFillColorSecondaryBrush}" StrokeThickness="2" />
                                    <Path Data="M12 6h5a2 2 0 0 1 2 2v7" />
                                    <Path Data="M15 9l-3-3 3-3" />
                                    <Path Data="M12 18H7a2 2 0 0 1-2-2V9" />
                                    <Path Data="M9 15l3 3-3 3" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock x:Name="GitLabel" Text="Git" Visibility="Collapsed" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="FilesTabButton" Style="{StaticResource SectionButtonStyle}"
                            Tag="Files" Click="DetailsTab_Click" ToolTipService.ToolTip="Files">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <!-- Lucide folder (stroke). -->
                            <Viewbox Width="15" Height="15">
                                <Canvas Width="24" Height="24">
                                    <Path Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                                          StrokeThickness="2" StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock x:Name="FilesLabel" Text="Files" Visibility="Collapsed" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Row 1: section bodies. x:Load="False" so this whole subtree is
                     NOT realized at window load — it only builds when the details panel
                     first opens (at 280px). Realizing ListView/ScrollViewer/TextBox in
                     the collapsed (Width=0) panel at startup crashed first layout. -->
                <!-- Always built, but Collapsed at startup so its heavy controls
                     (ListView/ScrollViewer/TextBox) skip first-layout measure — same
                     crash-avoidance x:Load gave, WITHOUT relying on FindName to realize
                     it (FindName never realizes x:Load in WinUI 3 → panels stayed empty).
                     SetDetails flips this Visible on first open. -->
                <Grid x:Name="DetailsBodyHost" Grid.Row="1" Visibility="Collapsed"
                      Tapped="DetailsBody_Tapped">

                    <!-- INFO -->
                    <ScrollViewer x:Name="InfoPanel" Padding="16,8,16,16">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Working Directory" FontWeight="SemiBold"
                                           FontSize="12" Opacity="0.7" />
                                <TextBlock x:Name="InfoCwd" Text="—" TextWrapping="Wrap"
                                           IsTextSelectionEnabled="True"
                                           FontFamily="Consolas, monospace" FontSize="12" />
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
                                    <Button Content="Copy Path" Click="InfoCopyPath_Click" />
                                    <Button Content="Reveal" Click="InfoReveal_Click" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Process" FontWeight="SemiBold"
                                           FontSize="12" Opacity="0.7" />
                                <TextBlock x:Name="InfoShell" Text="—" FontSize="12" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- OUTLINE: per-tab command history (renders via ToString). -->
                    <ListView x:Name="OutlineList" Visibility="Collapsed"
                              SelectionMode="None" Padding="6,4" />

                    <!-- GIT: porcelain status of the cwd's repo. Layout mirrors a
                         Fork-style sidebar: branch + diff stat, remote link, action
                         buttons, then the changed-file list. -->
                    <ScrollViewer x:Name="GitPanel" Visibility="Collapsed" Padding="16,12,16,16">
                        <StackPanel Spacing="14">
                            <!-- Branch + (+adds / −dels) -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="GitBranch" Grid.Column="0" Text="—"
                                           FontWeight="SemiBold" FontSize="18"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="GitAdds" Text="" FontSize="13"
                                               Foreground="#3FB950" FontFamily="Consolas, monospace" />
                                    <TextBlock x:Name="GitDels" Text="" FontSize="13"
                                               Foreground="#F85149" FontFamily="Consolas, monospace" />
                                </StackPanel>
                            </Grid>

                            <!-- Remote URL -->
                            <HyperlinkButton x:Name="GitRemote" Content="" FontSize="12"
                                             Padding="0" Margin="0,-8,0,0" Visibility="Collapsed" />

                            <!-- Action buttons -->
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <SplitButton x:Name="GitCommitBtn" Grid.Column="0"
                                             Content="Commit" HorizontalAlignment="Stretch"
                                             HorizontalContentAlignment="Center"
                                             Click="GitCommitBtn_Click">
                                    <SplitButton.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Commit" Click="GitCommit_Click" />
                                            <MenuFlyoutItem Text="Commit &amp; Push" Click="GitCommitPush_Click" />
                                            <MenuFlyoutItem Text="Amend last commit" Click="GitAmend_Click" />
                                        </MenuFlyout>
                                    </SplitButton.Flyout>
                                </SplitButton>
                                <SplitButton x:Name="GitForkBtn" Grid.Column="1"
                                             HorizontalAlignment="Stretch"
                                             HorizontalContentAlignment="Center"
                                             Click="GitForkBtn_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE895;" FontSize="13"
                                                  FontFamily="Segoe MDL2 Assets" />
                                        <TextBlock Text="Sync" />
                                    </StackPanel>
                                    <SplitButton.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Fetch" Click="GitFetch_Click" />
                                            <MenuFlyoutItem Text="Pull" Click="GitPull_Click" />
                                            <MenuFlyoutItem Text="Push" Click="GitPush_Click" />
                                        </MenuFlyout>
                                    </SplitButton.Flyout>
                                </SplitButton>
                            </Grid>

                            <!-- Unstaged header + stage-all -->
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="GitUnstagedLabel" Grid.Column="0" Text="Changes"
                                           FontWeight="SemiBold" FontSize="13" Opacity="0.85"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1" Style="{StaticResource IconButtonStyle}"
                                        Content="&#xE710;" Click="GitStageAll_Click"
                                        ToolTipService.ToolTip="Stage all" />
                            </Grid>

                            <!-- Changed files. Click a row to stage/unstage it. -->
                            <ListView x:Name="GitFiles" SelectionMode="None"
                                      IsItemClickEnabled="True" ItemClick="GitFiles_ItemClick"
                                      Padding="0" Margin="0,-4,0,0">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="MinHeight" Value="30" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:GitFileRow">
                                        <Grid ColumnSpacing="8" ToolTipService.ToolTip="{x:Bind FullPath}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="14" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind Status}"
                                                       Foreground="{x:Bind StatusBrush}"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       FontFamily="Consolas, monospace"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind Display}"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       TextTrimming="None" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- FILES: flat per-directory list + find/up/refresh/hidden. -->
                    <Grid x:Name="FilesPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Padding="12,4,8,4" ColumnSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="FilesFind" Grid.Column="0" PlaceholderText="Find"
                                     FontSize="12" TextChanged="FilesFind_TextChanged" />
                            <Button Grid.Column="1" Style="{StaticResource IconButtonStyle}"
                                    Content="&#xE74A;" Click="FilesUp_Click"
                                    ToolTipService.ToolTip="Parent folder" />
                            <Button Grid.Column="2" Style="{StaticResource IconButtonStyle}"
                                    Content="&#xE72C;" Click="FilesRefresh_Click"
                                    ToolTipService.ToolTip="Refresh" />
                            <Button Grid.Column="3" Style="{StaticResource IconButtonStyle}"
                                    Content="&#xE7B3;" Click="FilesHidden_Click"
                                    ToolTipService.ToolTip="Toggle hidden" />
                        </Grid>
                        <!-- Single click on a folder reveals its contents inline
                             (lazy-loaded on expand); double click sets it as the tree
                             root. Phosphor icons swap closed/open per node. -->
                        <muxc:TreeView x:Name="FilesTree" Grid.Row="1"
                                       SelectionMode="Single"
                                       CanDragItems="False" CanReorderItems="False"
                                       Expanding="FilesTree_Expanding"
                                       Collapsed="FilesTree_Collapsed"
                                       ItemInvoked="FilesTree_ItemInvoked"
                                       DoubleTapped="FilesList_DoubleTapped">
                            <muxc:TreeView.ItemTemplate>
                                <!-- Node mode: DataContext is the TreeViewNode; the
                                     FileItem is its Content. -->
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="6" Height="28">
                                        <!-- Classic Binding (not x:Bind): casting Content in an
                                             x:Bind path crashes the WinUI 1.6 XamlCompiler. -->
                                        <Path Data="{Binding Content.Icon, Mode=OneWay}"
                                              Width="16" Height="16" Stretch="Uniform"
                                              Fill="{ThemeResource TextFillColorSecondaryBrush}"
                                              VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Content.Name}" FontSize="13"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </muxc:TreeView.ItemTemplate>
                        </muxc:TreeView>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- Tabs panel: RIGHT column. Transparent so the backdrop blurs through; a
             hairline divider separates it from the terminal. Opening animates Width
             0 -> 280, pushing the terminal. Clipped during the animation. -->
        <Border x:Name="SidebarSurface"
                Grid.Column="2"
                Width="280"
                SizeChanged="Panel_ClipToBounds"
                BorderThickness="1,0,0,0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                Background="Transparent">
            <Grid x:Name="Sidebar" Width="280" HorizontalAlignment="Left">
                <Grid.RowDefinitions>
                    <RowDefinition Height="34" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 0: window controls (the toggle now lives in the title bar). -->
                <Grid Grid.Row="0">
                    <StackPanel x:Name="WindowControls"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch"
                                PointerEntered="Chrome_PointerEntered"
                                PointerExited="Chrome_PointerExited"
                                SizeChanged="TitleBar_SizeChanged">
                        <Button x:Name="MinButton" Click="Minimize_Click"
                                Style="{StaticResource CaptionButtonStyle}"
                                Content="&#xE921;" ToolTipService.ToolTip="Minimize" />
                        <Button x:Name="MaxButton" Click="MaximizeRestore_Click"
                                Style="{StaticResource CaptionButtonStyle}"
                                Content="&#xE922;" ToolTipService.ToolTip="Maximize" />
                        <Button x:Name="CloseButton" Click="CloseWindow_Click"
                                Style="{StaticResource CloseButtonStyle}"
                                Content="&#xE8BB;" ToolTipService.ToolTip="Close" />
                    </StackPanel>
                </Grid>

                <!-- Row 1: heading + add + filter. -->
                <Grid Grid.Row="1" Padding="14,0,8,0" ColumnSpacing="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="TABS"
                               VerticalAlignment="Center"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Opacity="0.55"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <!-- New-tab split control: + (default shell) and a chevron (profile
                         menu) read as one pill — the outer Border draws the unified
                         rounded outline; the inner buttons are transparent with a
                         hairline divider between them. -->
                    <Border x:Name="NewTabSplit"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Height="28"
                            CornerRadius="6"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            Background="{ThemeResource SubtleFillColorTransparentBrush}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch">
                            <Button x:Name="AddTabButton"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="5,0,0,5"
                                    Padding="8,0"
                                    VerticalAlignment="Stretch"
                                    MinWidth="0"
                                    MinHeight="0"
                                    VerticalContentAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    Click="AddTab_Click"
                                    ToolTipService.ToolTip="New tab (Ctrl+Shift+T)">
                                <Viewbox Width="15" Height="15"
                                         VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <!-- lucide plus (24x24 viewBox) -->
                                    <Path Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M12 5 V19 M5 12 H19" />
                                </Viewbox>
                            </Button>
                            <Border Width="1"
                                    Margin="0,5"
                                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            <Button x:Name="NewTabMenuButton"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="0,5,5,0"
                                    Padding="6,0"
                                    VerticalAlignment="Stretch"
                                    MinWidth="0"
                                    MinHeight="0"
                                    VerticalContentAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    Click="NewTabMenu_Click"
                                    ToolTipService.ToolTip="New tab profile">
                                <Viewbox Width="12" Height="12"
                                         VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <!-- lucide chevron-down (24x24 viewBox) -->
                                    <Path Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                                          StrokeThickness="2.5"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M6 9 L12 15 L18 9" />
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Border>
                    <Button x:Name="FilterButton"
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTipService.ToolTip="Filter">
                        <Viewbox Width="16" Height="16">
                            <!-- lucide list-filter (24x24 viewBox) -->
                            <Path Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                                  StrokeThickness="2"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M2 5 H22 M6 12 H18 M9 19 H15" />
                        </Viewbox>
                    </Button>
                </Grid>

                <!-- IsTabStop=False on the list AND its item containers: selecting a
                     tab (incl. programmatically on new-tab) must NOT pull keyboard
                     focus into the ListView, else input focus sticks there and the
                     terminal goes dead until the window is re-activated (the "can't
                     type after new tab until alt-tab" bug). -->
                <ListView x:Name="TabList"
                          Grid.Row="2"
                          Background="Transparent"
                          ItemsSource="{x:Bind TabListItems}"
                          SelectionMode="Single"
                          CanDragItems="True"
                          CanReorderItems="False"
                          AllowDrop="True"
                          IsTabStop="False"
                          AllowFocusOnInteraction="False"
                          SelectionChanged="TabList_SelectionChanged"
                          DragItemsStarting="TabList_DragItemsStarting"
                          DragItemsCompleted="TabList_DragItemsCompleted"
                          DragOver="TabList_DragOver"
                          Drop="TabList_Drop"
                          Tapped="TabList_Tapped"
                          ContextRequested="TabList_ContextRequested"
                          Padding="6,8,6,4">
                    <!-- No add/reorder transitions: new tabs appear instantly
                         instead of the slow default entrance animation. -->
                    <ListView.ItemContainerTransitions>
                        <TransitionCollection />
                    </ListView.ItemContainerTransitions>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="IsTabStop" Value="False" />
                            <Setter Property="MinHeight" Value="38" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <!-- Custom template: the default ListViewItemPresenter
                                 doesn't pick up the CornerRadius setter, so set it on
                                 the presenter directly (rounds the hover/selected
                                 fill). Indicator bar hidden to match the flat look. -->
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <p:ListViewItemPresenter
                                            CornerRadius="7"
                                            ContentMargin="10,0,8,0"
                                            HorizontalContentAlignment="Stretch"
                                            VerticalContentAlignment="Stretch"
                                            SelectionIndicatorBrush="Transparent"
                                            PointerOverBackground="Transparent"
                                            PressedBackground="Transparent"
                                            SelectedBackground="Transparent"
                                            SelectedPointerOverBackground="Transparent"
                                            SelectedPressedBackground="Transparent" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <!-- Footer: settings (round, hover-only chrome), bottom-right. -->
                <Grid Grid.Row="3" Padding="8,6">
                    <Button x:Name="SettingsButton"
                            HorizontalAlignment="Right"
                            Style="{StaticResource IconButtonStyle}"
                            CornerRadius="6"
                            Content="&#xE713;"
                            Click="Settings_Click"
                            ToolTipService.ToolTip="Settings" />
                </Grid>
            </Grid>
        </Border>

        <!-- Tabs toggle: lives in the terminal column (col 1), anchored to its right
             edge, so it tracks the panel boundary automatically as the column
             resizes — no manual transform needed. -->
        <Grid x:Name="ToggleHost"
              Grid.Column="1"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Height="34"
              Width="40"
              Opacity="0"
              PointerEntered="Chrome_PointerEntered"
              PointerExited="Chrome_PointerExited">
            <Button x:Name="PaneToggle"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Margin="0,0,4,0"
                    Style="{StaticResource IconButtonStyle}"
                    Click="PaneToggle_Click"
                    ToolTipService.ToolTip="Toggle sidebar (Ctrl+B)">
                <Grid Width="16" Height="16">
                    <Rectangle Width="15" Height="12" RadiusX="3.5" RadiusY="3.5"
                               Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                               StrokeThickness="1.4"
                               Fill="Transparent"
                               VerticalAlignment="Center" />
                    <Rectangle x:Name="ToggleBar"
                               Width="5" Height="7" RadiusX="1" RadiusY="1"
                               Fill="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Center"
                               Margin="0,0,3.5,0" />
                </Grid>
            </Button>
        </Grid>

        <!-- Details toggle: in the terminal column (col 1), anchored to its LEFT
             edge, so it tracks the details-panel boundary as the column resizes. -->
        <Grid x:Name="ToggleHostLeft"
              Grid.Column="1"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Height="34"
              Width="40"
              Opacity="0"
              PointerEntered="Chrome_PointerEntered"
              PointerExited="Chrome_PointerExited">
            <Button x:Name="DetailsToggle"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Margin="4,0,0,0"
                    Style="{StaticResource IconButtonStyle}"
                    Click="DetailsToggle_Click"
                    ToolTipService.ToolTip="Toggle details (Ctrl+Shift+B)">
                <Grid Width="16" Height="16">
                    <Rectangle Width="15" Height="12" RadiusX="3.5" RadiusY="3.5"
                               Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                               StrokeThickness="1.4"
                               Fill="Transparent"
                               VerticalAlignment="Center" />
                    <Rectangle x:Name="DetailsToggleBar"
                               Width="2" Height="7" RadiusX="1" RadiusY="1"
                               Fill="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Left" VerticalAlignment="Center"
                               Margin="3.5,0,0,0" />
                </Grid>
            </Button>
        </Grid>

        <!-- Command palette: full-window dim overlay + centered card. Light-dismiss
             by tapping the dim area; Esc closes. Opened with Ctrl+P / Ctrl+Shift+P. -->
        <Grid x:Name="PaletteOverlay"
              Grid.Column="0"
              Grid.ColumnSpan="3"
              Visibility="Collapsed"
              Background="#66000000"
              Tapped="PaletteOverlay_Tapped">
            <Border x:Name="PaletteCard"
                    Width="560"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Margin="0,-48,0,0"
                    Padding="8"
                    BorderBrush="#22FFFFFF"
                    BorderThickness="1"
                    CornerRadius="14"
                    Tapped="PaletteCard_Tapped">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Search row: magnifier glyph + borderless input (otty-style). -->
                    <Grid Grid.Row="0" Margin="2,2,2,8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0"
                                  Glyph="&#xE721;"
                                  FontFamily="Segoe MDL2 Assets"
                                  FontSize="15"
                                  Margin="6,0,0,0"
                                  VerticalAlignment="Center"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBox x:Name="PaletteSearch"
                                 Grid.Column="1"
                                 PlaceholderText="Search for commands…"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="15"
                                 TextChanged="PaletteSearch_TextChanged"
                                 KeyDown="PaletteSearch_KeyDown" />
                    </Grid>

                    <ListView x:Name="PaletteList"
                              Grid.Row="1"
                              ItemsSource="{x:Bind PaletteItems}"
                              SelectionMode="Single"
                              IsItemClickEnabled="True"
                              ItemClick="PaletteList_ItemClick"
                              MaxHeight="400">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="MinHeight" Value="38" />
                                <Setter Property="Margin" Value="0,1" />
                                <Setter Property="Padding" Value="10,0" />
                                <Setter Property="CornerRadius" Value="8" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:PaletteItem">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <!-- Leading check for active toggle rows. -->
                                    <FontIcon Grid.Column="0"
                                              Glyph="&#xE73E;"
                                              FontFamily="Segoe MDL2 Assets"
                                              FontSize="13"
                                              Visibility="{x:Bind CheckVis}"
                                              VerticalAlignment="Center"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Column="1" Text="{x:Bind Label}"
                                               VerticalAlignment="Center" />
                                    <!-- Shortcut shown as a rounded key-cap chip. -->
                                    <Border Grid.Column="2"
                                            Visibility="{x:Bind ShortcutVis}"
                                            Background="#1AFFFFFF"
                                            BorderBrush="#22FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            Padding="6,1"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Shortcut}"
                                                   FontSize="11"
                                                   Opacity="0.7" />
                                    </Border>
                                    <!-- Trailing chevron for submenu rows. -->
                                    <FontIcon Grid.Column="3"
                                              Glyph="&#xE76C;"
                                              FontFamily="Segoe MDL2 Assets"
                                              FontSize="12"
                                              Visibility="{x:Bind ChevronVis}"
                                              VerticalAlignment="Center"
                                              Opacity="0.5" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
